DATABASE_URL="postgresql://postgres:postgres@localhost:5432/work_portal?schema=public"
ENCRYPTION_KEY="replace-with-at-least-16-characters"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-random-secret-string"
GOOGLE_OAUTH_CLIENT_ID="replace-with-google-oauth-client-id"
GOOGLE_OAUTH_CLIENT_SECRET="replace-with-google-oauth-client-secret"
GOOGLE_DRIVE_REDIRECT_URI="http://localhost:3000/api/integrations/drive/callback"
GOOGLE_GMAIL_REDIRECT_URI="http://localhost:3000/api/integrations/gmail/callback"
# Required for public website attachment uploads through Vercel Blob.
# Pull from Vercel after connecting a Blob store: vercel env pull .env.local
BLOB_READ_WRITE_TOKEN="replace-with-vercel-blob-read-write-token"
# Optional Google scope overrides
# GOOGLE_DRIVE_OAUTH_SCOPE="https://www.googleapis.com/auth/drive.file https://www.googleapis.com/auth/drive.metadata.readonly"
# GOOGLE_GMAIL_OAUTH_SCOPE="https://www.googleapis.com/auth/gmail.metadata"
ENABLE_DEV_CREDENTIALS="false"
DEV_AUTH_EMAIL="sicpseoul@gmail.com"
DEV_AUTH_PASSWORD="change-this-password"
ACTIVE_TENANT_SLUG="sicp-senior-research"
DEV_AUTO_PROVISION="true"
BAND_CLIENT_ID="replace-with-band-client-id"
BAND_CLIENT_SECRET="replace-with-band-client-secret"
BAND_REDIRECT_URI="http://localhost:3000/api/integrations/band/callback"
# BAND 심사 상태 (PENDING_REVIEW | AVAILABLE)
BAND_APP_REVIEW_STATUS="PENDING_REVIEW"
# 심사 대기 안내 문구(선택)
# BAND_REVIEW_MESSAGE_KO="BAND 앱 키 발급 심사 중입니다. 심사 완료 후 BAND 연결 기능이 자동으로 활성화됩니다."
NAVER_IMAP_HOST="imap.naver.com"
NAVER_IMAP_PORT="993"
NAVER_IMAP_SECURE="true"
# Optional overrides
# BAND_AUTHORIZE_URL="https://auth.band.us/oauth2/authorize"
# BAND_TOKEN_URL="https://auth.band.us/oauth2/token"
# BAND_OAUTH_SCOPE="read_profile read_band"
