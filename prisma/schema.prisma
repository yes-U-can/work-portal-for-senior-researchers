generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum IntegrationProvider {
  BAND
  GOOGLE_DRIVE
  GMAIL
  NAVER_MAIL
}

enum IntegrationStatus {
  CONNECTED
  EXPIRED
  ERROR
}

enum ActionResult {
  SUCCESS
  DENIED
  ERROR
}

enum SitePostCategory {
  GENERAL
  WORKSHOP
  COUNSELING
  GREEN_BOARD
}

enum SiteContentVisibility {
  PUBLIC
  INTERNAL
  DRAFT
}

enum SiteAssistantKind {
  GPTS
  GEMINI_GEMS
}

model Tenant {
  id                String               @id @default(uuid())
  name              String
  slug              String               @unique
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  memberships       Membership[]
  accounts          IntegrationAccount[]
  auditLogs         AuditLog[]
  sitePosts         SitePost[]
  siteResources     SiteResource[]
  workshopSchedules WorkshopSchedule[]
  authorProfiles    AuthorProfile[]
  assistantLinks    SiteAssistantLink[]
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  name              String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  memberships       Membership[]
  auditLogs         AuditLog[]
  sitePosts         SitePost[]
  siteResources     SiteResource[]
  workshopSchedules WorkshopSchedule[]
  authorProfiles    AuthorProfile[]
  assistantLinks    SiteAssistantLink[]
}

model Membership {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, role])
}

model IntegrationAccount {
  id                String              @id @default(uuid())
  tenantId          String
  provider          IntegrationProvider
  providerAccountId String
  status            IntegrationStatus
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tokens            IntegrationToken[]
  cursors           SyncCursor[]

  @@unique([tenantId, provider, providerAccountId])
  @@index([tenantId, provider, status])
}

model IntegrationToken {
  id                    String             @id @default(uuid())
  integrationAccountId  String
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  expiresAt             DateTime?
  scope                 String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  account               IntegrationAccount @relation(fields: [integrationAccountId], references: [id], onDelete: Cascade)

  @@index([integrationAccountId])
}

model SyncCursor {
  id                   String             @id @default(uuid())
  integrationAccountId String
  cursorKey            String
  cursorValue          String
  updatedAt            DateTime           @updatedAt
  account              IntegrationAccount @relation(fields: [integrationAccountId], references: [id], onDelete: Cascade)

  @@unique([integrationAccountId, cursorKey])
}

model AuditLog {
  id           String       @id @default(uuid())
  tenantId     String
  actorUserId  String?
  action       String
  resourceType String
  resourceId   String?
  result       ActionResult
  metaJson     Json?
  createdAt    DateTime     @default(now())
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUser    User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
}

model AuthorProfile {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, displayName])
}

model SitePost {
  id           String                @id @default(uuid())
  tenantId     String
  authorUserId String?
  title        String
  body         String
  category     SitePostCategory
  labels       String[]              @default([])
  visibility   SiteContentVisibility @default(DRAFT)
  relatedLinks Json?
  attachments  Json?
  isPinned     Boolean               @default(false)
  pinnedRank   Int?
  deletedAt    DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author       User?                 @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, category, visibility])
  @@index([tenantId, deletedAt, updatedAt])
  @@index([tenantId, isPinned, pinnedRank])
}

model SiteResource {
  id           String                @id @default(uuid())
  tenantId     String
  authorUserId String?
  workshopSlug String
  session      String
  title        String
  description  String?
  url          String
  visibility   SiteContentVisibility @default(PUBLIC)
  deletedAt    DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author       User?                 @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, workshopSlug, visibility])
  @@index([tenantId, deletedAt, updatedAt])
}

model WorkshopSchedule {
  id                  String                @id @default(uuid())
  tenantId            String
  authorUserId        String?
  workshopSlug        String
  title               String
  description         String?
  applicationFormUrl  String?
  applicationStartsAt DateTime?
  applicationEndsAt   DateTime?
  workshopStartsAt    DateTime
  workshopEndsAt      DateTime?
  visibility          SiteContentVisibility @default(PUBLIC)
  deletedAt           DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author              User?                 @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, workshopSlug, visibility])
  @@index([tenantId, deletedAt, workshopStartsAt])
  @@index([tenantId, updatedAt])
}

model SiteAssistantLink {
  id           String                @id @default(uuid())
  tenantId     String
  authorUserId String?
  kind         SiteAssistantKind
  title        String
  description  String?
  url          String
  glyph        String
  sortOrder    Int                   @default(100)
  visibility   SiteContentVisibility @default(PUBLIC)
  deletedAt    DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author       User?                 @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, kind, visibility])
  @@index([tenantId, deletedAt, sortOrder])
}
